{
  "cases": [
    {
      "name": "darwin-not-misdetected-as-windows",
      "platform": "macos",
      "arch": "arm64",
      "assets": [
        "Logseq-darwin-arm64-2.0.1.dmg",
        "Logseq-darwin-x64-2.0.1.dmg",
        "Logseq-win-arm64-2.0.1-nsis.exe",
        "Logseq-linux-x86_64-2.0.1.AppImage"
      ],
      "expected": "Logseq-darwin-arm64-2.0.1.dmg"
    },
    {
      "name": "windows-still-detected",
      "platform": "windows",
      "arch": "arm64",
      "assets": [
        "Logseq-darwin-arm64-2.0.1.dmg",
        "Logseq-win-arm64-2.0.1-nsis.exe"
      ],
      "expected": "Logseq-win-arm64-2.0.1-nsis.exe"
    },
    {
      "name": "prefers-vanilla-over-profile-arm64",
      "platform": "macos",
      "arch": "arm64",
      "assets": [
        "bun-darwin-aarch64-profile.zip",
        "bun-darwin-aarch64.zip",
        "bun-darwin-x64-baseline-profile.zip",
        "bun-darwin-x64-baseline.zip",
        "bun-darwin-x64-profile.zip",
        "bun-darwin-x64.zip"
      ],
      "expected": "bun-darwin-aarch64.zip"
    },
    {
      "name": "prefers-vanilla-over-profile-amd64",
      "platform": "macos",
      "arch": "amd64",
      "assets": [
        "bun-darwin-aarch64-profile.zip",
        "bun-darwin-aarch64.zip",
        "bun-darwin-x64-baseline-profile.zip",
        "bun-darwin-x64-baseline.zip",
        "bun-darwin-x64-profile.zip",
        "bun-darwin-x64.zip"
      ],
      "expected": "bun-darwin-x64.zip"
    },
    {
      "name": "falls-back-to-variant-when-only-option",
      "platform": "macos",
      "arch": "arm64",
      "assets": [
        "tool-darwin-arm64-profile.zip",
        "tool-linux-amd64.tar.gz"
      ],
      "expected": "tool-darwin-arm64-profile.zip"
    },
    {
      "name": "hard-arch-filter-prefers-matching-over-better-ext",
      "platform": "linux",
      "arch": "amd64",
      "assets": [
        "tool-linux-arm64.AppImage",
        "tool-linux-amd64.deb"
      ],
      "expected": "tool-linux-amd64.deb"
    },
    {
      "name": "no-extension-no-keyword-fallback",
      "platform": "linux",
      "arch": "amd64",
      "assets": ["mytool-linux-amd64", "mytool-linux-amd64.tar.gz"],
      "expected": "mytool-linux-amd64.tar.gz"
    },
    {
      "name": "bare-binary-without-extension-is-ignored",
      "platform": "linux",
      "arch": "amd64",
      "assets": ["mytool-linux-amd64"],
      "expected": null
    },
    {
      "name": "unknown-arch-uses-extension-rank-only",
      "platform": "macos",
      "arch": "",
      "assets": [
        "app-darwin-arm64.zip",
        "app-darwin-x64.dmg"
      ],
      "expected": "app-darwin-x64.dmg"
    },
    {
      "name": "skips-source-archives",
      "platform": "linux",
      "arch": "amd64",
      "assets": [
        "tool-linux-amd64-source.tar.gz",
        "tool-linux-amd64.tar.gz"
      ],
      "expected": "tool-linux-amd64.tar.gz"
    },
    {
      "name": "skips-bare-versioned-tarball",
      "platform": "linux",
      "arch": "amd64",
      "assets": [
        "htop-3.5.2.tar.xz",
        "htop-3.5.2.tar.xz.sha256"
      ],
      "expected": null
    },
    {
      "name": "keeps-platform-tagged-tarball",
      "platform": "linux",
      "arch": "amd64",
      "assets": ["tool-linux-amd64.tar.xz"],
      "expected": "tool-linux-amd64.tar.xz"
    },
    {
      "name": "android-picks-apk",
      "platform": "android",
      "arch": "arm64",
      "assets": [
        "App-1.0.0.apk",
        "App-1.0.0.ipa",
        "App-linux-x86_64.AppImage",
        "App-darwin-arm64.dmg"
      ],
      "expected": "App-1.0.0.apk"
    },
    {
      "name": "android-prefers-apk-over-aab",
      "platform": "android",
      "arch": "",
      "assets": [
        "App-1.0.0.aab",
        "App-1.0.0.apk"
      ],
      "expected": "App-1.0.0.apk"
    },
    {
      "name": "android-falls-back-to-aab",
      "platform": "android",
      "arch": "",
      "assets": [
        "App-1.0.0.aab",
        "App-darwin-arm64.dmg"
      ],
      "expected": "App-1.0.0.aab"
    },
    {
      "name": "ios-picks-ipa",
      "platform": "ios",
      "arch": "arm64",
      "assets": [
        "App-1.0.0.apk",
        "App-1.0.0.ipa",
        "App-darwin-arm64.dmg",
        "App-win-x64.exe"
      ],
      "expected": "App-1.0.0.ipa"
    },
    {
      "name": "android-skips-other-platform-named-apk",
      "platform": "android",
      "arch": "",
      "assets": [
        "App-ios.apk",
        "App-android.apk"
      ],
      "expected": "App-android.apk"
    },
    {
      "name": "linux-does-not-pick-apk",
      "platform": "linux",
      "arch": "amd64",
      "assets": [
        "App-1.0.0.apk",
        "App-linux-amd64.AppImage"
      ],
      "expected": "App-linux-amd64.AppImage"
    },
    {
      "name": "macos-does-not-pick-ipa",
      "platform": "macos",
      "arch": "arm64",
      "assets": [
        "App-1.0.0.ipa",
        "App-darwin-arm64.dmg"
      ],
      "expected": "App-darwin-arm64.dmg"
    },
    {
      "name": "android-no-mobile-asset-returns-null",
      "platform": "android",
      "arch": "",
      "assets": [
        "App-darwin-arm64.dmg",
        "App-linux-amd64.AppImage",
        "App-win-x64.exe"
      ],
      "expected": null
    },
    {
      "name": "ios-no-mobile-asset-returns-null",
      "platform": "ios",
      "arch": "",
      "assets": [
        "App-darwin-arm64.dmg",
        "App-1.0.0.apk"
      ],
      "expected": null
    }
  ]
}
